{
  "manifest_version": 3,
  "name": "NetSuite Scripts Manager",
  "version": "1.0.3",
  "description": "NetSuite Scripts Manager - View Scripts & Workflows Instantly",
  "permissions": ["activeTab", "storage", "scripting"],
  "icons": {
    "16": "img/icon16.png",
    "32": "img/icon32.png",
    "48": "img/icon48.png",
    "128": "img/icon128.png"
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "action": {
    "default_title": "NetSuite Scripts Manager",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [{
    "resources": ["js/nsmain.js", "js/nsscheduler.js"],
    "matches": ["https://*.netsuite.com/*"]
  }]
}
